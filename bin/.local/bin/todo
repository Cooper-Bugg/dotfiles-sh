#!/usr/bin/env python3
import os

TODO_FILE = os.path.expanduser("~/docs/md/todo.md")

# Cyberpunk Colors (ANSI escape sequences)
BLUE = "\033[38;5;75m"
GOLD = "\033[38;5;214m"
RED = "\033[38;5;203m"
GRAY = "\033[38;5;244m"
RESET = "\033[0m"
BOLD = "\033[1m"

def print_todo():
    if not os.path.exists(TODO_FILE):
        print(f"{RED}Error: todo.md not found at {TODO_FILE}{RESET}")
        return

    print(f"\n{BLUE}{BOLD}🌌 Bugg-OS Active Tasks{RESET}")
    print(f"{GOLD}──────────────────────────────────────────{RESET}")

    current_section = ""
    tasks_count = 0
    
    with open(TODO_FILE, 'r') as f:
        for line in f:
            stripped = line.strip()
            if stripped.startswith("## "):
                current_section = stripped[3:].strip()
                print(f"\n{BLUE}{BOLD}# {current_section}{RESET}")
            elif stripped.startswith("- [ ]"):
                task_text = stripped[5:].strip()
                print(f"  {GOLD}❯{RESET} {task_text}")
                tasks_count += 1
            elif stripped.startswith("- [x]"):
                task_text = stripped[5:].strip()
                print(f"  {GRAY}✔  {task_text}{RESET}")

    print(f"\n{GOLD}──────────────────────────────────────────{RESET}")
    if tasks_count == 0:
        print(f"🎉 {BLUE}{BOLD}No pending tasks! All clear.{RESET}\n")
    else:
        print(f"📝 {BLUE}{BOLD}{tasks_count} pending tasks.{RESET} Run {GOLD}bvim ~/docs/md/todo.md{RESET} to edit.\n")

if __name__ == "__main__":
    print_todo()
